---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimalCard from '../../components/AnimalCard.astro';
import { site } from '../../config/site';

const { family } = site.copy;
const byName = (a: CollectionEntry<'residents'>, b: CollectionEntry<'residents'>) =>
  a.data.name.localeCompare(b.data.name);

const all = await getCollection('residents');
const living = all.filter((e) => !e.data.memorial).sort(byName);
const remembered = all.filter((e) => e.data.memorial).sort(byName);
---

<BaseLayout title={family.title}>
  <section class="section">
    <div class="container">
      <h1>{family.title}</h1>
      <p class="intro">{family.intro}</p>
      {
        living.length > 0 ? (
          <ul class="animal-grid">
            {living.map((e) => (
              <li>
                <AnimalCard
                  name={e.data.name}
                  href={`/family/${e.id}`}
                  photo={e.data.photo}
                  meta={e.data.species}
                />
              </li>
            ))}
          </ul>
        ) : (
          <p class="intro">The family portraits are on their way.</p>
        )
      }
    </div>
  </section>

  {
    remembered.length > 0 && (
      <section class="section memorial-section">
        <div class="container">
          <h2>{family.memorialHeading}</h2>
          <p>{family.memorialBlurb}</p>
          <ul class="animal-grid">
            {remembered.map((e) => (
              <li>
                <AnimalCard
                  name={e.data.name}
                  href={`/family/${e.id}`}
                  photo={e.data.photo}
                  meta={`${e.data.species} · In loving memory`}
                />
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .intro {
    margin-top: var(--space-3);
    font-size: 1.15rem;
  }

  .memorial-section {
    border-top: var(--border-hairline);
  }
</style>
