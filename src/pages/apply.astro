---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteForm from '../components/SiteForm.astro';
import { site } from '../config/site';

// Fields mirror the owner's real cat + dog adoption applications (Google
// Forms, 2026-07-08 / 2026-07-12) merged into one form: shared questions once,
// species-specific sections shown by the selector below (auto-set when the
// visitor arrives from an animal's Apply button).
const { apply } = site.copy;

// slug → name/species, so /apply?pet={slug} prefills BOTH fields
const adoptables = await getCollection('adoptables');
const petMap = Object.fromEntries(
  adoptables.map((e) => [e.id, { name: e.data.name, species: e.data.species }])
);
---

<BaseLayout title={apply.title}>
  <section class="section">
    <div class="container">
      <h1>{apply.title}</h1>
      <p class="intro">{apply.intro}</p>
      <SiteForm formName="adoption-application" subject="Adoption application — website" submitLabel="Send application">
        <fieldset>
          <legend>Who are you applying for?</legend>
          <div class="form-field">
            <label for="ap-pet">The animal's name *</label>
            <input id="ap-pet" name="pet" type="text" required />
          </div>
          <div class="form-field">
            <label for="ap-species">Cat or dog? *</label>
            <select id="ap-species" name="species" required>
              <option value="">Choose one…</option>
              <option>Cat</option>
              <option>Dog</option>
              <option>Other</option>
            </select>
          </div>
        </fieldset>

        <fieldset>
          <legend>About you</legend>
          <div class="form-field">
            <label for="ap-name">Full name *</label>
            <input id="ap-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="ap-email">Email *</label>
            <input id="ap-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="form-field">
            <label for="ap-phone">Phone number *</label>
            <input id="ap-phone" name="phone" type="tel" required autocomplete="tel" />
          </div>
          <div class="form-field">
            <label for="ap-address">Full address *</label>
            <input id="ap-address" name="address" type="text" required autocomplete="street-address" />
          </div>
        </fieldset>

        <fieldset>
          <legend>Your home</legend>
          <div class="form-field">
            <label for="ap-ownrent">Do you own or rent your home? *</label>
            <select id="ap-ownrent" name="own_or_rent" required>
              <option value="">Choose one…</option>
              <option>Own</option>
              <option>Rent</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-landlord-ok">If renting, is your landlord okay with pets?</label>
            <select id="ap-landlord-ok" name="landlord_ok">
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
              <option>N/A</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-landlord">Landlord's contact information (if renting)</label>
            <input id="ap-landlord" name="landlord_contact" type="text" />
          </div>
          <div class="form-field">
            <label for="ap-children">How many children live in your home, and their ages? *</label>
            <input id="ap-children" name="children" type="text" required placeholder="e.g. none / two kids, 6 and 9" />
          </div>
          <div class="form-field">
            <label for="ap-atmosphere">How would you describe your home atmosphere? *</label>
            <input id="ap-atmosphere" name="home_atmosphere" type="text" required placeholder="loud / busy / quiet / calm" />
          </div>
          <div class="form-field">
            <label for="ap-allergies">Does anyone in your home have allergies? *</label>
            <select id="ap-allergies" name="allergies" required>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-onboard">Is everyone in your home on board with adopting? *</label>
            <select id="ap-onboard" name="family_on_board" required>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
        </fieldset>

        <fieldset>
          <legend>Your animals, past and present</legend>
          <div class="form-field">
            <label for="ap-haspets">Do you currently have other pets? *</label>
            <select id="ap-haspets" name="has_other_pets" required>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-currentpets">Tell us about the pets currently in your home</label>
            <textarea
              id="ap-currentpets"
              name="current_pets"
              placeholder="Breed or species, age, fixed or not, temperament…"></textarea>
          </div>
          <div class="form-field">
            <label for="ap-pastpets">Any previous pets? Tell us about them</label>
            <textarea
              id="ap-pastpets"
              name="previous_pets"
              placeholder="Breed or species, age, and where they are now."></textarea>
          </div>
          <div class="form-field">
            <label for="ap-vet">Current vet's contact information</label>
            <input id="ap-vet" name="vet_contact" type="text" />
          </div>
        </fieldset>

        {/* Species sections: JS shows the matching one and enforces its required
            fields (data-req). Without JS both stay visible and optional. */}
        <fieldset data-species="Cat">
          <legend>Life with your cat</legend>
          <div class="form-field">
            <label for="ap-outdoors">Would they be allowed outdoors? If yes, tell us more *</label>
            <textarea id="ap-outdoors" name="outdoors" data-req></textarea>
          </div>
        </fieldset>

        <fieldset data-species="Dog">
          <legend>Life with your dog</legend>
          <div class="form-field">
            <label for="ap-yard">Do you have a fenced yard? *</label>
            <select id="ap-yard" name="fenced_yard" data-req>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-daycare">Would they be going to doggy daycare? *</label>
            <select id="ap-daycare" name="doggy_daycare" data-req>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-crate">Will they be crate trained? *</label>
            <select id="ap-crate" name="crate_trained" data-req>
              <option value="">Choose one…</option>
              <option>Yes</option>
              <option>No</option>
            </select>
          </div>
          <div class="form-field">
            <label for="ap-training">
              Do you plan on enrolling in formal training classes? If not, tell us about your
              experience training dogs
            </label>
            <textarea id="ap-training" name="training_plan"></textarea>
          </div>
          <div class="form-field">
            <label for="ap-exercise">Realistically, how much time per day do you have to exercise them? *</label>
            <input id="ap-exercise" name="daily_exercise" type="text" data-req />
          </div>
        </fieldset>

        <fieldset>
          <legend>Life together</legend>
          <div class="form-field">
            <label for="ap-alone">How long would they be alone on a typical day? *</label>
            <input id="ap-alone" name="hours_alone" type="text" required />
          </div>
          <div class="form-field">
            <label for="ap-personality">Describe your ideal companion's personality *</label>
            <input
              id="ap-personality"
              name="ideal_personality"
              type="text"
              required
              placeholder="playful, relaxed, active, independent, lap cat…"
            />
          </div>
          <div class="form-field">
            <label for="ap-anything">Anything else you'd like to share, or questions for us</label>
            <textarea id="ap-anything" name="anything_else"></textarea>
          </div>
        </fieldset>
      </SiteForm>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-block: var(--space-3) var(--space-4);
    font-size: 1.15rem;
    max-width: 60ch;
  }
</style>

<script is:inline define:vars={{ petMap }}>
  // §5 prefill: /apply?pet={slug} fills the name AND selects the species,
  // so visitors arriving from an animal's Apply button never think about it.
  const speciesSelect = document.getElementById('ap-species');
  const petInput = document.getElementById('ap-pet');
  const sections = [...document.querySelectorAll('fieldset[data-species]')];

  const applySpecies = () => {
    for (const s of sections) {
      const active = s.dataset.species === speciesSelect.value;
      s.hidden = !active;
      s.disabled = !active;
      for (const el of s.querySelectorAll('[data-req]')) el.required = active;
    }
  };
  speciesSelect.addEventListener('change', applySpecies);

  const pet = new URLSearchParams(window.location.search).get('pet');
  if (pet) {
    const known = petMap[pet];
    if (known) {
      if (!petInput.value) petInput.value = known.name;
      speciesSelect.value = known.species;
    } else if (!petInput.value) {
      petInput.value = pet;
    }
  }
  applySpecies();
</script>
