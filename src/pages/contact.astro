---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteForm from '../components/SiteForm.astro';
import { site } from '../config/site';

const { contact } = site.copy;
---

<BaseLayout title={contact.title}>
  <section class="section">
    <div class="container contact-inner">
      <div>
        <h1>{contact.title}</h1>
        <p class="intro">{contact.intro}</p>

        <h2>{contact.formHeading}</h2>
        <SiteForm formName="contact" subject="Message from the website" submitLabel="Send">
          <div class="form-field">
            <label for="ct-name">Your name *</label>
            <input id="ct-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="ct-email">Your email *</label>
            <input id="ct-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="form-field">
            <label for="ct-message">Your message *</label>
            <textarea id="ct-message" name="message" required></textarea>
          </div>
        </SiteForm>
      </div>

      <aside class="contact-side">
        <h2>Where we are</h2>
        <p>{site.location} — we'll share exact details when we arrange a visit.</p>
        <h2>Email</h2>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        <h2>Find us online</h2>
        <ul class="social-list">
          <li><a href={site.social.instagram}>Instagram</a></li>
          <li><a href={site.social.youtube}>YouTube</a></li>
          <li><a href={site.social.facebook}>Facebook</a></li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  .intro {
    margin-block: var(--space-3) var(--space-4);
    font-size: 1.15rem;
  }

  h2 {
    margin-bottom: var(--space-3);
  }

  .contact-side h2 {
    margin-top: var(--space-4);
  }

  .contact-side h2:first-child {
    margin-top: 0;
  }

  .contact-side p {
    margin-bottom: var(--space-3);
  }

  .social-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  @media (max-width: 800px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
