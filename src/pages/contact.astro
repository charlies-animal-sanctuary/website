---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const { contact, formPrivacyNote } = site.copy;
const formWired = !site.formEndpoint.startsWith('#');
---

<BaseLayout title={contact.title}>
  <section class="section">
    <div class="container contact-inner">
      <div>
        <p class="placeholder-chip">Draft copy — final wording comes from the owner</p>
        <h1>{contact.title}</h1>
        <p class="intro">{contact.intro}</p>

        <h2>{contact.formHeading}</h2>
        {!formWired && (
          <p class="placeholder-chip">Form not wired yet — submissions go nowhere until phase 4</p>
        )}
        <form class="form-grid" method="POST" action={site.formEndpoint}>
          <input type="hidden" name="form_name" value="contact" />
          <div class="form-field">
            <label for="ct-name">Your name *</label>
            <input id="ct-name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="ct-email">Your email *</label>
            <input id="ct-email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="form-field">
            <label for="ct-message">Your message *</label>
            <textarea id="ct-message" name="message" required></textarea>
          </div>
          <div class="hp-field" aria-hidden="true">
            <label for="ct-website">Leave this field empty</label>
            <input id="ct-website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <button class="btn btn--primary" type="submit">Send</button>
          <p class="form-note">{formPrivacyNote}</p>
        </form>
      </div>

      <aside class="contact-side">
        <h2>Where we are</h2>
        <p>{site.location} — we'll share exact details when we arrange a visit.</p>
        <h2>Find us online</h2>
        <ul class="social-list">
          <li><a href={site.social.instagram}>Instagram</a></li>
          <li><a href={site.social.youtube}>YouTube</a></li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  .intro {
    margin-block: var(--space-3) var(--space-4);
    font-size: 1.15rem;
  }

  h2 {
    margin-bottom: var(--space-3);
  }

  .contact-side h2 {
    margin-top: var(--space-4);
  }

  .contact-side h2:first-child {
    margin-top: 0;
  }

  .contact-side p {
    margin-bottom: var(--space-3);
  }

  .social-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  @media (max-width: 800px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
