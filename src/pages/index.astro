---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimalCard from '../components/AnimalCard.astro';
import { site } from '../config/site';
import heroImage from '../assets/hero/charlie-pasture.jpg';

const { home } = site.copy;

// §5: feature `featured: true` Available animals; fall back to any Available;
// hide the section entirely when there are none.
const adoptables = await getCollection('adoptables');
const availableAll = adoptables.filter((e) => e.data.status === 'Available');
let featured = availableAll.filter((e) => e.data.featured);
if (featured.length === 0) featured = availableAll;
featured = featured.slice(0, 2);

const metaOf = (d: CollectionEntry<'adoptables'>['data']) =>
  [d.species, d.sex, d.age, d.size].filter(Boolean).join(' · ');

const highlights = (await getCollection('highlights')).sort(
  (a, b) => a.data.order - b.data.order
);

// Render guard for the owner-pasted link field (schema is deliberately lenient)
const tileHref = (link: string | undefined) =>
  link?.startsWith('http') ? link : site.social.instagram;
---

<BaseLayout>
  <section class="section hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>{home.heroHeadline}</h1>
        <p>{home.heroSub}</p>
        <div class="cta-row">
          <a class="btn btn--primary" href="/adopt">Meet the animals</a>
          <a class="btn btn--secondary" href={site.donateUrl}>Donate</a>
        </div>
      </div>
      <div class="hero-media">
        <Image
          src={heroImage}
          alt="Two blanketed horses grazing in a green pasture beneath golden autumn trees"
          width={1000}
          widths={[480, 800, 1000]}
          sizes="(max-width: 800px) 92vw, 45vw"
          class="hero-photo"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="section">
        <div class="container">
          <h2>{home.featuredHeading}</h2>
          <ul class="featured-grid">
            {featured.map((e) => (
              <li>
                <AnimalCard
                  name={e.data.name}
                  href={`/adopt/${e.id}`}
                  photo={e.data.photo}
                  meta={metaOf(e.data)}
                  status={e.data.status}
                  slug={e.id}
                />
              </li>
            ))}
          </ul>
          <a class="featured-link" href="/adopt">
            See everyone looking for a home →
          </a>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container video-block">
      <h2>{home.videoHeading}</h2>
      <div class="video-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${site.youtubeStoryVideoId}`}
          title={`${home.videoHeading} — ${site.name}`}
          loading="lazy"
          allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>
      </div>
    </div>
  </section>

  {
    highlights.length > 0 && (
      <section class="section">
        <div class="container">
          <h2>{home.instagramHeading}</h2>
          <ul class="ig-grid">
            {highlights.map((h) => (
              <li>
                <a href={tileHref(h.data.link)} rel="noopener">
                  <Image src={h.data.photo} alt={h.data.title} width={480} class="ig-photo" />
                </a>
              </li>
            ))}
          </ul>
          <a class="btn btn--secondary" href={site.social.instagram}>Follow on Instagram</a>
        </div>
      </section>
    )
  }

  {/* owner 2026-07-11: no button here — the footer's Donate sits right below */}
  <section class="section section--dark donate-section">
    <div class="container donate-band">
      <h2>{home.donateHeading}</h2>
      <p>{home.donateSub}</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  .cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .hero-text p {
    margin-top: var(--space-3);
  }

  .hero-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    border: var(--border-hairline);
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 18rem));
    gap: var(--space-4);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }

  .featured-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: 600;
  }

  .video-block .video-frame {
    aspect-ratio: 16 / 9;
    max-width: 46rem;
    margin-top: var(--space-3);
    border-radius: var(--radius-card);
    overflow: hidden;
    border: var(--border-hairline);
  }

  .video-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: var(--space-3);
    list-style: none;
    margin: var(--space-3) 0 var(--space-4);
    padding: 0;
  }

  .ig-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius-card);
    border: var(--border-hairline);
    display: block;
  }

  /* band and footer share the ebony background — trim the dead space between */
  .donate-section {
    padding-block: var(--space-5) var(--space-3);
  }

  .donate-band {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--space-3);
  }
</style>
