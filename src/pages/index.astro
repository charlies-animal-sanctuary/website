---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PlaceholderBlock from '../components/PlaceholderBlock.astro';
import AnimalCard from '../components/AnimalCard.astro';
import { site } from '../config/site';

const { home } = site.copy;

// §5: feature `featured: true` Available animals; fall back to any Available;
// hide the section entirely when there are none.
const adoptables = await getCollection('adoptables');
const availableAll = adoptables.filter((e) => e.data.status === 'Available');
let featured = availableAll.filter((e) => e.data.featured);
if (featured.length === 0) featured = availableAll;
featured = featured.slice(0, 2);

const metaOf = (d: CollectionEntry<'adoptables'>['data']) =>
  [d.species, d.sex, d.age, d.size].filter(Boolean).join(' · ');
---

<BaseLayout>
  <section class="section hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="placeholder-chip">Draft copy — final voice comes from the owner</p>
        <h1>{home.heroHeadline}</h1>
        <p>{home.heroSub}</p>
        <div class="cta-row">
          <a class="btn btn--primary" href="/adopt">Meet the animals</a>
          <a class="btn btn--secondary" href={site.donateUrl}>Donate</a>
        </div>
      </div>
      <div class="hero-media">
        <PlaceholderBlock label="Hero photo — a strong still, chosen by the owner (v1 ships a still; looped clip is a fast-follow)" ratio="4 / 3" />
      </div>
    </div>
  </section>

  {
    featured.length > 0 && (
      <section class="section">
        <div class="container">
          <h2>{home.featuredHeading}</h2>
          <p class="placeholder-chip">Sample animals — real ones replace them via /admin</p>
          <ul class="featured-grid">
            {featured.map((e) => (
              <li>
                <AnimalCard
                  name={e.data.name}
                  href={`/adopt/${e.id}`}
                  photo={e.data.photo}
                  meta={metaOf(e.data)}
                  status={e.data.status}
                  slug={e.id}
                />
              </li>
            ))}
          </ul>
          <a class="featured-link" href="/adopt">
            See everyone looking for a home →
          </a>
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container video-block">
      <h2>{home.videoHeading}</h2>
      {
        site.youtubeStoryVideoId ? (
          <p>Video embed renders here once wired (phase 4).</p>
        ) : (
          <PlaceholderBlock
            label="YouTube embed — needs the featured video ID (§11); wired click-to-play in phase 4"
            ratio="16 / 9"
          />
        )
      }
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{home.instagramHeading}</h2>
      <p class="placeholder-chip">Sample tiles — the live Behold feed arrives in phase 4</p>
      <ul class="ig-grid">
        {[1, 2, 3, 4, 5, 6].map((n) => (
          <li><PlaceholderBlock label={`Instagram post ${n}`} ratio="1 / 1" /></li>
        ))}
      </ul>
      <a class="btn btn--secondary" href={site.social.instagram}>Follow on Instagram</a>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container donate-band">
      <h2>{home.donateHeading}</h2>
      <p>{home.donateSub}</p>
      <a class="btn btn--primary" href={site.donateUrl}>Donate</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }

  .cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .hero-text p {
    margin-top: var(--space-3);
  }

  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 18rem));
    gap: var(--space-4);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }

  .featured-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: 600;
  }

  .video-block :global(.ph-block) {
    max-width: 46rem;
    margin-top: var(--space-3);
  }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: var(--space-3);
    list-style: none;
    margin: var(--space-3) 0 var(--space-4);
    padding: 0;
  }

  .donate-band {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--space-3);
  }
</style>
