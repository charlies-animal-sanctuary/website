---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
// developer-owned copies — never import from CMS-managed media folders
import charliePortrait from '../assets/about/charlie-portrait.jpg';
import katherynCharlie from '../assets/about/katheryn-charlie.jpg';

const { about } = site.copy;
---

<BaseLayout title={about.title}>
  <section class="section">
    <div class="container about-inner">
      <div class="about-text">
        <h1>{about.title}</h1>
        <p class="about-intro">{about.intro}</p>
        {
          about.sections.map((s) => (
            <section class="about-section">
              <h2>{s.heading}</h2>
              {s.paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </section>
          ))
        }
      </div>
      <aside class="about-media">
        <figure>
          <Image
            src={charliePortrait}
            alt="Charlie, a chestnut horse in a bridle, beside a pasture fence"
            width={640}
            class="about-photo"
          />
          <figcaption>Charlie — Sir Charles to his friends.</figcaption>
        </figure>
        <figure>
          <Image
            src={katherynCharlie}
            alt="Katheryn in a pink cap, smiling, while Charlie rests his muzzle against her head"
            width={640}
            class="about-photo"
          />
          <figcaption>Katheryn and Charlie.</figcaption>
        </figure>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-5);
    align-items: start;
  }

  .about-text p {
    margin-top: var(--space-3);
  }

  .about-intro {
    font-size: 1.15rem;
  }

  .about-section {
    margin-top: var(--space-5);
  }

  .about-media {
    display: grid;
    gap: var(--space-4);
    position: sticky;
    top: var(--space-4);
  }

  .about-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    border: var(--border-hairline);
  }

  figure {
    margin: 0;
  }

  figcaption {
    font-size: 0.9rem;
    margin-top: var(--space-2);
  }

  @media (max-width: 800px) {
    .about-inner {
      grid-template-columns: 1fr;
    }

    .about-media {
      position: static;
    }
  }
</style>
