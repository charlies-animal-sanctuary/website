---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimalCard from '../../components/AnimalCard.astro';
import { site } from '../../config/site';

// §5: Happy Tails grows forever by design — paginated so it never slows down.
export const getStaticPaths = (async ({ paginate }) => {
  const adopted = (
    await getCollection('adoptables', ({ data }) => data.status === 'Adopted')
  ).sort(
    (a, b) => (b.data.adopted_date?.getTime() ?? 0) - (a.data.adopted_date?.getTime() ?? 0)
  );
  return paginate(adopted, { pageSize: 24 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { adopt } = site.copy;
// distinct titles per paginated page — avoids duplicate <title>/og:title
const pageTitle =
  page.currentPage > 1
    ? `${adopt.happyTailsHeading} — page ${page.currentPage}`
    : adopt.happyTailsHeading;
---

<BaseLayout title={pageTitle}>
  <section class="section">
    <div class="container">
      <h1>{adopt.happyTailsHeading}</h1>
      <p class="intro">{adopt.happyTailsBlurb}</p>
      {
        page.data.length > 0 ? (
          <ul class="animal-grid">
            {page.data.map((e) => (
              <li>
                <AnimalCard
                  name={e.data.name}
                  href={`/adopt/${e.id}`}
                  photo={e.data.photo}
                  status="Adopted"
                  adoptedDate={e.data.adopted_date}
                />
              </li>
            ))}
          </ul>
        ) : (
          <p class="intro">No happy tails yet — the first one is coming.</p>
        )
      }
      {
        (page.url.prev || page.url.next) && (
          <nav class="pagination" aria-label="Happy Tails pages">
            {page.url.prev && <a href={page.url.prev}>← Newer</a>}
            <span>
              Page {page.currentPage} of {page.lastPage}
            </span>
            {page.url.next && <a href={page.url.next}>Older →</a>}
          </nav>
        )
      }
      <a class="back-link" href="/adopt">← Animals looking for homes</a>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-top: var(--space-3);
    font-size: 1.15rem;
  }

  .pagination {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    margin-top: var(--space-4);
    font-weight: 600;
  }

  .back-link {
    display: inline-block;
    margin-top: var(--space-4);
    font-weight: 600;
  }
</style>
