---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteForm from '../components/SiteForm.astro';
import { site } from '../config/site';

const { intake } = site.copy;
---

<BaseLayout title={intake.title}>
  <section class="section">
    <div class="container">
      <h1>{intake.title}</h1>
      <p class="intro">{intake.intro}</p>
      <p class="note">{intake.note}</p>
      <ol class="steps">
        {intake.steps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>

  <section class="section form-section">
    <div class="container">
      <h2>{intake.formHeading}</h2>
      <SiteForm formName="intake-surrender" subject="Intake / surrender request — website" submitLabel="Send">
        <div class="form-field">
          <label for="in-name">Your name *</label>
          <input id="in-name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label for="in-email">Your email *</label>
          <input id="in-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="in-phone">Phone (optional)</label>
          <input id="in-phone" name="phone" type="tel" autocomplete="tel" />
        </div>
        <div class="form-field">
          <label for="in-species">What kind of animal? *</label>
          <select id="in-species" name="species" required>
            <option value="">Choose one…</option>
            <option>Cat</option>
            <option>Dog</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-field">
          <label for="in-location">Where is the animal right now? *</label>
          <input
            id="in-location"
            name="location"
            type="text"
            required
            placeholder="e.g. my home in Peterborough, a barn near Lakefield…"
          />
        </div>
        <div class="form-field">
          <label for="in-age">Approximate age, if you know it</label>
          <input id="in-age" name="approximate_age" type="text" placeholder="e.g. kitten, ~2 years, senior" />
        </div>
        <div class="form-field">
          <label for="in-health">Any health concerns you've noticed?</label>
          <input id="in-health" name="health_concerns" type="text" />
        </div>
        <div class="form-field">
          <label for="in-details">Tell me about the animal and the situation *</label>
          <textarea
            id="in-details"
            name="details"
            required
            placeholder="Temperament, history, why they need a new home — as much as you can share."></textarea>
        </div>
      </SiteForm>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-top: var(--space-3);
    font-size: 1.15rem;
  }

  .note {
    margin-top: var(--space-3);
    max-width: 60ch;
  }

  .steps {
    margin-top: var(--space-3);
    padding-left: 1.2em;
    max-width: 60ch;
  }

  .steps li {
    margin-top: var(--space-2);
  }

  .form-section h2 {
    margin-bottom: var(--space-3);
  }
</style>
